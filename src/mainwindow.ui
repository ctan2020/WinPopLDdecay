 <class>MainWindow</class>
 <widget class="QMainWindow" name="MainWindow">
  <property name="geometry">
   <rect>
    <x>0</x>
    <y>0</y>
    <width>1800</width>
    <height>700</height>
   </rect>
  </property>
  <property name="windowTitle">
   <string>PopLDdecay GUI - 连锁不平衡衰减分析工具</string>
  </property>
   <property name="styleSheet">
   <string notr="true">/* 固定主窗口与内容区背景为白色，不随系统主题变化 */
QMainWindow { background-color: #ffffff; }
QWidget#centralwidget { background-color: #ffffff; }
/* 固定字体与颜色为当前样式 */
QGroupBox { font-weight: bold; font-size: 14px; color: #000000; border: 2px solid #bdc3c7; border-radius: 8px; margin-top: 10px; padding-top: 10px; background-color: #ffffff; }
QGroupBox::title { subcontrol-origin: margin; left: 10px; padding: 0 5px 0 5px; color: #000000; font-weight: bold; font-size: 14px; }
QLabel { color: #000000; font-size: 12px; font-weight: 500; }
QTextEdit { background-color: #ffffff; border: 2px solid #bdc3c7; border-radius: 8px; padding: 8px; font-family: 'Consolas', 'Monaco', monospace; font-size: 11px; color: #000000; }
QSpinBox, QDoubleSpinBox, QLineEdit { background-color: #ffffff; border: 2px solid #bdc3c7; border-radius: 6px; padding: 4px 8px; font-size: 12px; min-height: 20px; color: #000000; }
QSpinBox:focus, QDoubleSpinBox:focus, QLineEdit:focus { border-color: #3498db; color: #000000; }
QMenuBar { background-color: #ffffff; color: #000000; }
QStatusBar { background-color: #ffffff; color: #000000; }</string>
  </property>
  <widget class="QWidget" name="centralwidget">
   <layout class="QHBoxLayout" name="mainHLayout">
    <item>
     <layout class="QVBoxLayout" name="mainVLayout">
      <item>
       <widget class="QGroupBox" name="groupBox_vcf">
        <property name="title">
         <string>生成结果文件</string>
        </property>
        <layout class="QHBoxLayout" name="vcfLayout">
         <item>
          <widget class="QPushButton" name="selectVCFFiles">
           <property name="styleSheet">
            <string notr="true">QPushButton {background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #667eea, stop:1 #764ba2); color: white; border: none; border-radius: 20px; font-size: 14px; font-weight: bold; padding: 12px 28px; min-width: 180px; box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);} QPushButton:hover {background: qlineargradient(x1:0, y1:0, x2:1, y2:1, stop:0 #764ba2, stop:1 #667eea); transform: translateY(-2px); box-shadow: 0 6px 20px rgba(102, 126, 234, 0.4);} QPushButton:pressed {transform: translateY(0px);}</string>
           </property>
           <property name="text">
            <string>📁 选择VCF文件（可多选）</string>
           </property>
          </widget>
         </item>
         <item>
          <widget class="QPushButton" name="selectSubpopFile">
